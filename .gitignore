# =============================================================================
# .gitignore — BlindBag Marketplace
# =============================================================================

# --- IDE / Editor ---
.vscode/
.idea/
*.suo
*.user

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- Environment / Secrets ---
.env
.env.*
!.env.example

# --- Docker ---
# Không ignore Dockerfile hoặc docker-compose, chỉ ignore volume data
docker/volumes/

# --- Build outputs ---
bin/
obj/
dist/
build/
out/

# --- Node.js ---
node_modules/
npm-debug.log*

# --- .NET ---
*.user
*.vs/
*.nupkg
*.snupkg
**/bin/
**/obj/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
